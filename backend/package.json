{
  "name": "ledgermate-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node ./dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "test:integration": "tsx scripts/integration-workspace-chat.ts",
    "test:security": "tsx scripts/integration-security-rbac.ts",
    "test:ci": "npm run test:integration && npm run test:security",
    "rehearsal:staging-migration": "bash ./scripts/staging-migration-rehearsal.sh",
    "ops:verify-backup-retention": "node ./scripts/verify-backup-retention.mjs",
    "ops:run-auto-renewals": "tsx scripts/run-auto-renewals.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@prisma/client": "^5.10.0",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prisma": "^5.10.0",
    "tsx": "^3.12.7",
    "typescript": "^5.5.4"
  }
}
