generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  revenue
  expense
}

enum TransactionEventType {
  cash_sale
  momo_sale
  credit_sale
  debtor_recovery
  stock_purchase
  operating_expense
  owner_withdrawal
  loan_received
  loan_repayment
  supplier_credit
  capital_introduced
  other
}

enum TransactionStatus {
  draft
  confirmed
}

enum SubscriptionStatus {
  free
  premium
  trial
}

enum PeriodType {
  weekly
  monthly
}

enum ConversationChannel {
  web
  whatsapp
}

enum CustomLineItemKind {
  inflow
  expense
}

enum WebhookProvider {
  twilio
  infobip
  generic
}

model User {
  id                 String             @id @default(cuid())
  name               String
  phoneNumber        String             @unique
  businessName       String?
  businessType       String?
  preferredTime      String?
  timezone           String?
  subscriptionStatus SubscriptionStatus @default(free)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  transactions       Transaction[]
  summaries          Summary[]
  budgets            Budget[]
  conversationSessions ConversationSession[]
  processedWebhookEvents ProcessedWebhookEvent[]
  customLineItems    CustomLineItem[]
}

model Transaction {
  id               String               @id @default(cuid())
  user             User                 @relation(fields: [userId], references: [id])
  userId           String
  type             TransactionType
  eventType        TransactionEventType @default(other)
  status           TransactionStatus    @default(confirmed)
  amount           Float
  date             DateTime
  category         String?
  notes            String?
  correctionReason String?
  correctionOfId   String?
  correctionOf     Transaction?         @relation("TransactionCorrections", fields: [correctionOfId], references: [id])
  corrections      Transaction[]        @relation("TransactionCorrections")
  confirmedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Summary {
  id               String      @id @default(cuid())
  user             User        @relation(fields: [userId], references: [id])
  userId           String
  periodType       PeriodType
  periodStart      DateTime
  periodEnd        DateTime
  totalRevenue     Float
  totalExpenses    Float
  profit           Float
  transactionCount Int
  details          Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum BudgetTargetType {
  expense
  revenue
}

model Budget {
  id          String           @id @default(cuid())
  user        User             @relation(fields: [userId], references: [id])
  userId      String
  periodType  PeriodType
  periodStart DateTime
  periodEnd   DateTime
  targetType  BudgetTargetType
  amount      Float
  category    String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ConversationSession {
  id        String              @id @default(cuid())
  user      User                @relation(fields: [userId], references: [id])
  userId    String
  channel   ConversationChannel @default(web)
  step      String              @default("idle")
  context   Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel])
}

model CustomLineItem {
  id              String             @id @default(cuid())
  user            User               @relation(fields: [userId], references: [id])
  userId          String
  kind            CustomLineItemKind
  label           String
  normalizedLabel String
  usageCount      Int                @default(1)
  lastUsedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, kind, normalizedLabel])
  @@index([userId, kind])
}

model ProcessedWebhookEvent {
  id        String          @id @default(cuid())
  provider  WebhookProvider
  eventId   String
  user      User?           @relation(fields: [userId], references: [id])
  userId    String?
  payload   Json?
  createdAt DateTime        @default(now())

  @@unique([provider, eventId])
}
