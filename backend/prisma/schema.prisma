generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  revenue
  expense
}

enum TransactionEventType {
  cash_sale
  momo_sale
  credit_sale
  debtor_recovery
  stock_purchase
  operating_expense
  owner_withdrawal
  loan_received
  loan_repayment
  supplier_credit
  capital_introduced
  other
}

enum TransactionStatus {
  draft
  confirmed
}

enum TransactionSourceChannel {
  whatsapp
  app
  system
}

enum SubscriptionStatus {
  free
  basic
  premium
  trial
}

enum PeriodType {
  weekly
  monthly
}

enum ConversationChannel {
  web
  whatsapp
  telegram
}

enum CustomLineItemKind {
  inflow
  expense
}

enum WebhookProvider {
  twilio
  infobip
  generic
}

enum WhatsAppProvider {
  twilio
  infobip
  whatchimp
}

enum SubscriptionGrantSource {
  trial
  paid
  referral_bonus
  admin_adjustment
}

enum SubscriptionPaymentProvider {
  paystack
}

enum SubscriptionPaymentStatus {
  pending
  successful
  failed
}

enum UserStatus {
  pending
  active
  inactive
  suspended
}

enum MembershipRole {
  owner
  cashier
  manager
  bookkeeper
  viewer
  accountant
}

enum MembershipStatus {
  invited
  active
  inactive
  revoked
}

enum ApprovalStatus {
  not_required
  pending
  approved
  rejected
}

enum DocumentType {
  receipt
  invoice
  payment_confirmation
  momo_screenshot
  bank_transfer
  utility_bill
  rent_receipt
  other
}

enum ProductServiceType {
  product
  service
}

enum BusinessCategoryKind {
  sales
  expense
}

enum LedgerAccountType {
  asset
  liability
  equity
  income
  expense
}

enum LedgerPostingStatus {
  not_configured
  pending
  posted
  failed
  skipped
}

enum ParseConfidence {
  high
  medium
  low
}

enum LedgerEntryStatus {
  draft
  posted
  needs_review
  void
}

enum ReconciliationChannel {
  cash
  momo
}

model User {
  id                           String               @id @default(cuid())
  name                         String
  fullName                     String?
  email                        String?              @unique
  phoneNumber                  String               @unique
  whatsappNumber               String?
  telegramChatId               String?              @unique
  telegramUsername             String?
  businessName                 String?
  businessType                 String?
  preferredTime                String?
  timezone                     String?
  currencyCode                 String               @default("GHS")
  status                       UserStatus           @default(active)
  subscriptionStatus           SubscriptionStatus   @default(free)
  trialEndsAt                  DateTime?
  subscriptionEndsAt           DateTime?
  freeSubscriptionMonthsEarned Int                  @default(0)
  referralCode                 String?              @unique
  referredByUserId             String?
  referredBy                   User?                @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals                    User[]               @relation("UserReferrals")
  isSuperAdmin                 Boolean              @default(false)
  activeBusinessId             String?
  activeBusiness               Business?            @relation("UserActiveBusiness", fields: [activeBusinessId], references: [id])
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  transactions                 Transaction[]        @relation("LegacyUserTransactions")
  createdTransactions          Transaction[]        @relation("TransactionCreator")
  approvedTransactions         Transaction[]        @relation("TransactionApprover")
  summaries                    Summary[]
  budgets                      Budget[]
  conversationSessions         ConversationSession[]
  processedWebhookEvents       ProcessedWebhookEvent[]
  customLineItems              CustomLineItem[]
  referralConversionsAsReferrer ReferralConversion[] @relation("ReferrerConversions")
  referralConversionAsReferred  ReferralConversion[] @relation("ReferredConversions")
  referralRewards              ReferralReward[]
  subscriptionGrants           SubscriptionGrant[]
  subscriptionPayments         SubscriptionPayment[]
  ownedBusinesses              Business[]           @relation("BusinessOwner")
  primaryWhatsappBusinesses    Business[]           @relation("BusinessWhatsappOwner")
  memberships                  BusinessMembership[] @relation("MembershipUser")
  membershipInvitesSent        BusinessMembership[] @relation("MembershipInviter")
  performedAuditLogs           AuditLog[]
  uploadedDocuments            Document[]
  requestedApprovals           TransactionApproval[] @relation("ApprovalRequester")
  reviewedApprovals            TransactionApproval[] @relation("ApprovalReviewer")
  sessions                     UserSession[]
  reconciliationSessions       ReconciliationSession[]
}

model Business {
  id                     String                @id @default(cuid())
  businessName           String
  businessType           String?
  currencyCode           String                @default("GHS")
  enabledPaymentMethods  Json?
  onboardingVersion      Int                   @default(1)
  onboardingCompletedAt  DateTime?
  ownerUserId            String
  primaryWhatsappUserId  String
  timezone               String                @default("Africa/Accra")
  subscriptionStatus     SubscriptionStatus    @default(free)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  owner                  User                  @relation("BusinessOwner", fields: [ownerUserId], references: [id])
  primaryWhatsappUser    User                  @relation("BusinessWhatsappOwner", fields: [primaryWhatsappUserId], references: [id])
  usersWithActiveBusiness User[]               @relation("UserActiveBusiness")
  memberships            BusinessMembership[]
  transactions           Transaction[]
  summaries              Summary[]
  budgets                Budget[]
  conversationSessions   ConversationSession[]
  customLineItems        CustomLineItem[]
  auditLogs              AuditLog[]
  documents              Document[]
  subscriptionGrants     SubscriptionGrant[]
  subscriptionPayments   SubscriptionPayment[]
  sessions               UserSession[]
  categories             BusinessCategory[]
  products               ProductService[]
  customers              Customer[]
  suppliers              Supplier[]
  ledgerAccounts         LedgerAccount[]
  journalEntries         LedgerJournalEntry[]
  reconciliationSessions ReconciliationSession[]

  @@index([ownerUserId])
  @@index([primaryWhatsappUserId])
}

model BusinessMembership {
  id               String           @id @default(cuid())
  businessId       String
  userId           String
  role             MembershipRole
  membershipStatus MembershipStatus @default(invited)
  invitedByUserId  String?
  joinedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user             User             @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser    User?            @relation("MembershipInviter", fields: [invitedByUserId], references: [id])

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId, role])
}

model Transaction {
  id               String               @id @default(cuid())
  businessId       String?
  user             User                 @relation("LegacyUserTransactions", fields: [userId], references: [id])
  userId           String
  createdByUserId  String
  approvedByUserId String?
  sourceChannel    TransactionSourceChannel @default(app)
  type             TransactionType
  eventType        TransactionEventType @default(other)
  status           TransactionStatus    @default(confirmed)
  amount           Float
  date             DateTime
  category         String?
  notes            String?
  correctionReason String?
  rawInputText     String?
  parseConfidence  ParseConfidence      @default(high)
  requiresReview   Boolean              @default(false)
  interpretedFields Json?
  correctionOfId   String?
  customerId       String?
  supplierId       String?
  productServiceId String?
  businessCategoryId String?
  correctionOf     Transaction?         @relation("TransactionCorrections", fields: [correctionOfId], references: [id])
  corrections      Transaction[]        @relation("TransactionCorrections")
  approvalStatus   ApprovalStatus       @default(not_required)
  ledgerPostingStatus LedgerPostingStatus @default(not_configured)
  isDeleted        Boolean              @default(false)
  confirmedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  business         Business?            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdByUser    User                 @relation("TransactionCreator", fields: [createdByUserId], references: [id])
  approvedByUser   User?                @relation("TransactionApprover", fields: [approvedByUserId], references: [id])
  customer         Customer?            @relation(fields: [customerId], references: [id])
  supplier         Supplier?            @relation(fields: [supplierId], references: [id])
  productService   ProductService?      @relation(fields: [productServiceId], references: [id])
  businessCategory BusinessCategory?    @relation(fields: [businessCategoryId], references: [id])
  approvals        TransactionApproval[]
  documents        Document[]
  journalEntries   LedgerJournalEntry[]

  @@index([businessId, date])
  @@index([businessId, createdByUserId])
  @@index([businessId, approvalStatus])
  @@index([businessId, type])
  @@index([businessId, customerId])
  @@index([businessId, supplierId])
  @@index([businessId, productServiceId])
  @@index([businessId, businessCategoryId])
}

model BusinessCategory {
  id             String               @id @default(cuid())
  businessId     String
  kind           BusinessCategoryKind
  name           String
  normalizedName String
  isDefault      Boolean              @default(false)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  business       Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products       ProductService[]
  transactions   Transaction[]

  @@unique([businessId, kind, normalizedName])
  @@index([businessId, kind, isActive])
}

model ProductService {
  id             String             @id @default(cuid())
  businessId     String
  categoryId     String?
  name           String
  normalizedName String
  type           ProductServiceType @default(product)
  defaultPrice   Float?
  estimatedCost  Float?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  business       Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category       BusinessCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions   Transaction[]

  @@unique([businessId, normalizedName])
  @@index([businessId, type, isActive])
}

model Customer {
  id               String        @id @default(cuid())
  businessId       String
  name             String
  normalizedName   String
  phoneNumber      String?
  notes            String?
  openingReceivable Float        @default(0)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  business         Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@unique([businessId, normalizedName])
  @@index([businessId, isActive])
}

model Supplier {
  id             String      @id @default(cuid())
  businessId     String
  name           String
  normalizedName String
  phoneNumber    String?
  supplyType     String?
  notes          String?
  openingPayable Float       @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  business       Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@unique([businessId, normalizedName])
  @@index([businessId, isActive])
}

model LedgerAccount {
  id             String            @id @default(cuid())
  businessId     String
  code           String
  name           String
  normalizedName String
  accountType    LedgerAccountType
  isSystemDefault Boolean          @default(false)
  isActive       Boolean           @default(true)
  parentId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent         LedgerAccount?    @relation("LedgerAccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       LedgerAccount[]   @relation("LedgerAccountHierarchy")
  journalLines   LedgerJournalLine[]

  @@unique([businessId, code])
  @@unique([businessId, normalizedName])
  @@index([businessId, accountType, isActive])
}

model LedgerJournalEntry {
  id                 String            @id @default(cuid())
  businessId         String
  transactionId      String?
  entryDate          DateTime
  description        String?
  status             LedgerEntryStatus @default(draft)
  source             String            @default("system")
  createdByUserId    String?
  approvedByUserId   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  business           Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transaction        Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  lines              LedgerJournalLine[]

  @@index([businessId, entryDate])
  @@index([transactionId])
}

model LedgerJournalLine {
  id          String           @id @default(cuid())
  entryId     String
  accountId   String
  debitAmount Float            @default(0)
  creditAmount Float           @default(0)
  memo        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  entry       LedgerJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account     LedgerAccount    @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
}

model ReconciliationSession {
  id             String                @id @default(cuid())
  businessId     String
  createdByUserId String
  channel        ReconciliationChannel
  asOf           DateTime
  bookBalance    Float
  countedBalance Float
  variance       Float
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdByUser  User                  @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([businessId, channel, asOf])
  @@index([createdByUserId])
}

model TransactionApproval {
  id                String         @id @default(cuid())
  transactionId     String
  requestedByUserId String
  reviewedByUserId  String?
  status            ApprovalStatus @default(pending)
  reason            String?
  reviewNote        String?
  requestedAt       DateTime       @default(now())
  reviewedAt        DateTime?
  transaction       Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  requestedByUser   User           @relation("ApprovalRequester", fields: [requestedByUserId], references: [id])
  reviewedByUser    User?          @relation("ApprovalReviewer", fields: [reviewedByUserId], references: [id])

  @@index([transactionId])
  @@index([status])
}

model Summary {
  id               String      @id @default(cuid())
  businessId       String?
  user             User        @relation(fields: [userId], references: [id])
  userId           String
  periodType       PeriodType
  periodStart      DateTime
  periodEnd        DateTime
  totalRevenue     Float
  totalExpenses    Float
  profit           Float
  transactionCount Int
  details          Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  business         Business?   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, periodType, periodStart])
}

enum BudgetTargetType {
  expense
  revenue
}

model Budget {
  id          String           @id @default(cuid())
  businessId  String?
  user        User             @relation(fields: [userId], references: [id])
  userId      String
  periodType  PeriodType
  periodStart DateTime
  periodEnd   DateTime
  targetType  BudgetTargetType
  amount      Float
  category    String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  business    Business?        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, periodType, periodStart])
}

model ConversationSession {
  id         String              @id @default(cuid())
  businessId String?
  user       User                @relation(fields: [userId], references: [id])
  userId     String
  channel    ConversationChannel @default(web)
  step       String              @default("idle")
  context    Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  business   Business?           @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
}

model CustomLineItem {
  id              String             @id @default(cuid())
  businessId      String?
  user            User               @relation(fields: [userId], references: [id])
  userId          String
  kind            CustomLineItemKind
  label           String
  normalizedLabel String
  usageCount      Int                @default(1)
  lastUsedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  business        Business?          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, normalizedLabel])
  @@index([userId, kind])
}

model ProcessedWebhookEvent {
  id         String          @id @default(cuid())
  provider   WebhookProvider
  eventId    String
  businessId String?
  user       User?           @relation(fields: [userId], references: [id])
  userId     String?
  payload    Json?
  createdAt  DateTime        @default(now())

  @@unique([provider, eventId])
}

model ReferralConversion {
  id             String   @id @default(cuid())
  referrer       User     @relation("ReferrerConversions", fields: [referrerId], references: [id])
  referrerId     String
  referredUser   User     @relation("ReferredConversions", fields: [referredUserId], references: [id])
  referredUserId String   @unique
  referralCode   String?
  qualifiedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([referrerId])
}

model ReferralReward {
  id                        String   @id @default(cuid())
  referrer                  User     @relation(fields: [referrerId], references: [id])
  referrerId                String
  milestone                 Int
  qualifiedReferralsAtGrant Int
  grantedMonths             Int      @default(3)
  createdAt                 DateTime @default(now())

  @@unique([referrerId, milestone])
  @@index([referrerId, createdAt])
}

model SubscriptionGrant {
  id            String                 @id @default(cuid())
  businessId    String?
  user          User                   @relation(fields: [userId], references: [id])
  userId        String
  source        SubscriptionGrantSource
  status        SubscriptionStatus
  monthsGranted Int                    @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  note          String?
  metadata      Json?
  createdAt     DateTime               @default(now())
  business      Business?              @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([businessId, createdAt])
}

model SubscriptionPayment {
  id              String                      @id @default(cuid())
  businessId      String?
  user            User                        @relation(fields: [userId], references: [id])
  userId          String
  provider        SubscriptionPaymentProvider @default(paystack)
  reference       String                      @unique
  amountMinor     Int
  currencyCode    String                      @default("GHS")
  monthsPurchased Int                         @default(1)
  status          SubscriptionPaymentStatus   @default(pending)
  paidAt          DateTime?
  channel         String?
  customerEmail   String?
  metadata        Json?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  business        Business?                   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id                String   @id @default(cuid())
  businessId        String
  entityType        String
  entityId          String
  action            String
  oldValue          Json?
  newValue          Json?
  performedByUserId String?
  performedAt       DateTime @default(now())
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  performedByUser   User?    @relation(fields: [performedByUserId], references: [id])

  @@index([businessId, performedAt])
  @@index([entityType, entityId])
}

model Document {
  id               String       @id @default(cuid())
  businessId       String
  transactionId    String
  uploadedByUserId String
  fileUrl          String
  fileName         String?
  mimeType         String?
  fileSizeBytes    BigInt?
  documentType     DocumentType @default(other)
  uploadedAt       DateTime     @default(now())
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transaction      Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploadedByUser   User         @relation(fields: [uploadedByUserId], references: [id])

  @@index([businessId])
  @@index([transactionId])
}

model OtpCode {
  id             String   @id @default(cuid())
  phoneNumber    String
  codeHash       String
  codeLast4      String
  expiresAt      DateTime
  consumedAt     DateTime?
  attempts       Int      @default(0)
  requestedByIp  String?
  createdAt      DateTime @default(now())

  @@index([phoneNumber, createdAt])
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  businessId       String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId, businessId])
}

model AppConfig {
  id                    String           @id @default("global")
  whatsappProvider      WhatsAppProvider @default(whatchimp)
  paystackPublicKey     String?
  paystackSecretKey     String?
  paystackWebhookSecret String?
  paystackBasicAmount   Int              @default(60)
  paystackPremiumAmount Int              @default(200)
  paystackCurrencyCode  String           @default("GHS")
  whatchimpBaseUrl      String?
  whatchimpApiKey       String?
  whatchimpSenderId     String?
  whatchimpSendPath     String           @default("/api/messages/whatsapp")
  whatchimpAuthScheme   String           @default("Bearer")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}
