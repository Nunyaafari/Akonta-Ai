POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ledgermate

# Public app URL used for CORS and callbacks.
APP_ORIGIN=https://app.akonta.local

# Optional explicit DB URL override.
# DATABASE_URL=postgresql://postgres:change_me@db:5432/ledgermate

# Mounted secret directory path from your secret manager agent/CSI driver.
SECRETS_MOUNT_PATH=/var/run/akonta-secrets

# TLS cert directory with fullchain.pem and privkey.pem
TLS_CERTS_PATH=./docker/certs
